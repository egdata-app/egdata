{
  "compilerOptions": {
    "jsx": "react-jsx",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "types": ["node"],
    "lib": ["ESNext", "DOM", "WebWorker"],
    "plugins": [
      {
        "name": "gql.tada/ts-plugin",
        "schema": "http://localhost:4000/graphql",
        "tadaOutputLocation": "./src/graphql-env.d.ts"
      }
    ]
  },
  "include": ["src", "global.d.ts", "*.config.ts"]
}
